<meta charset="UTF-8">
<meta name="viewport"
      content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="ie=edge">
<meta name="theme-color" content="#ffffff">
<% if (config.author) { %><meta name="author" content="<%- config.author %>"><% } %>
<% if (config.subtitle) { %><meta name="subtitle" content="<%- config.subtitle %>"><% } %>
<%
var description = '';
if (is_post() || is_page()) {
  description = strip_html(page.excerpt || page.content || '').replace(/\\/g, '').replace(/\s+/g, ' ').substring(0, 200).trim();
}
if (!description && config.description) {
  description = config.description;
}
if (description) { %>
<meta name="description" content="<%- description.replace(/"/g, '&quot;') %>">
<% } %>
<% if (config.keywords) { %><meta name="keywords" content="<%- config.keywords %>"><% } %>
<%
var title = page.title;

if (is_archive()){
    title = __('archive_a');

    if (is_month()){
        title += ': ' + page.year + '/' + page.month;
    } else if (is_year()){
        title += ': ' + page.year;
    }
} else if (is_category()){
    title = __('category') + ': ' + page.category;
} else if (is_tag()){
    title = __('tag') + ': ' + page.tag;
}
%>
<title><% if (title){ %><%= title %> | <% } %><%= config.title %></title>

<%# favicons %>
<% if (theme.icons){ %>
<link rel="apple-touch-icon" sizes="180x180" href="<%- url_for('/icons/apple-touch-icon.png', { ignore: true }) %>">
<link rel="icon" type="image/png" sizes="32x32" href="<%- url_for('/icons/favicon-32x32.png', { ignore: true }) %>">
<link rel="icon" type="image/png" sizes="16x16" href="<%- url_for('/icons/favicon-16x16.png', { ignore: true }) %>">
<link rel="manifest" href="<%- url_for('/icons/site.webmanifest', { ignore: true }) %>">
<% } %>

<% if (is_archive()) { %>
<meta name="robots" content="noindex">
<% } %>
<%- autoCanonical(config, page) %>
<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml">

<%# Open Graph %>
<%
var ogImage = '';
if (is_post() || is_page()) {
  var imgMatch = (page.content || '').match(/<img[^>]+src=["']([^"']+)["']/);
  if (imgMatch) {
    ogImage = imgMatch[1];
    if (ogImage.startsWith('http')) {
      // already absolute
    } else if (ogImage.startsWith('/')) {
      ogImage = config.url + ogImage;
    } else {
      var basePath = url_for(page.path).replace(/[^/]*$/, '');
      ogImage = config.url + basePath + ogImage.replace(/^\.\//, '');
    }
  }
}
if (!ogImage && theme.logos && theme.logos.avatar) {
  ogImage = config.url + url_for(theme.logos.avatar, { ignore: true });
}
if (!ogImage) ogImage = config.url + '/icons/apple-touch-icon.png';
%>
<meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
<meta property="og:title" content="<%= title ? title + ' | ' + config.title : config.title %>">
<% if (description) { %>
<meta property="og:description" content="<%- description.replace(/"/g, '&quot;') %>">
<% } %>
<meta property="og:url" content="<%- page.permalink || config.url %>">
<meta property="og:site_name" content="<%= config.title %>">
<meta property="og:image" content="<%- ogImage %>">

<%# css list %>
<% if (theme.stylesheets !== undefined && theme.stylesheets.length > 0) { %>
<!-- stylesheets list from _config.yml -->
<% theme.stylesheets.forEach(url => { %>
<link rel="stylesheet" href="<%- url_for(url, { ignore: true }) %>">
<% }); %>
<% } %>

<%# javascript list %>
<% if (theme.scripts !== undefined && theme.scripts.length > 0) { %>
<!-- scripts list from _config.yml -->
<% theme.scripts.forEach(url => { %>
<script src="<%- url_for(url, { ignore: true }) %>"></script>
<% }); %>
<% } %>

<%# JSON-LD structured data %>
<% if (is_post()) { %>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": page.title,
  "url": page.permalink,
  "datePublished": page.date ? page.date.toISOString() : undefined,
  "dateModified": page.updated ? page.updated.toISOString() : undefined,
  "author": page.author ? { "@type": "Person", "name": page.author } : undefined,
  "description": description || undefined,
  "publisher": {
    "@type": "Organization",
    "name": config.title
  }
}) %>
</script>
<% } else if (is_home()) { %>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": config.title,
  "url": config.url,
  "description": config.description || undefined
}) %>
</script>
<% } %>

<style>
  <%- fa_css() %>
</style>
