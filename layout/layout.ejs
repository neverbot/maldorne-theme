<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
    <%- partial('_partial/head',{cache: true}) %>
</head>
<body>
    <%# SVG clip-path for hexagon post edges — hidden, referenced by CSS %>
    <svg width="0" height="0" style="position:absolute">
      <defs>
        <clipPath id="hexagon-clip" clipPathUnits="objectBoundingBox">
          <path d="M 0,0.015
                   C 0.08,0.005 0.15,0.02 0.25,0.008
                   C 0.35,0 0.45,0.018 0.55,0.005
                   C 0.65,0 0.75,0.015 0.85,0.005
                   C 0.92,0 0.97,0.01 1,0.008
                   L 1,0.985
                   C 0.92,0.995 0.85,0.98 0.75,0.992
                   C 0.65,1 0.55,0.982 0.45,0.995
                   C 0.35,1 0.25,0.985 0.15,0.995
                   C 0.08,1 0.03,0.99 0,0.992
                   Z" />
        </clipPath>
      </defs>
    </svg>
    <div class="wrapper">
        <%- partial('_partial/header',{cache: true}) %>
        <main class="main">
            <%- body %>
        </main>
        <%- partial('_partial/footer',{cache: true}) %>
    </div>
</body>
</html>
