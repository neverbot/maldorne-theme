
// Tooltip appears BELOW the icon
.hovertext:before
  content attr(data-hover)
  visibility hidden
  opacity 0
  width max-content
  max-width 220px
  background-color rgba(0, 0, 0, 0.9)
  color #fff
  text-align center
  border-radius 0
  padding 8px 14px
  font-size 0.85em
  font-family system-ui, -apple-system, sans-serif
  line-height 1.4
  transition opacity 0.2s ease
  position absolute
  z-index 10
  left 50%
  transform translateX(-50%)
  top calc(100% + 18px)
  pointer-events none

// Arrow pointing up — connects white icon square to dark tooltip
.hovertext:after
  content ""
  visibility hidden
  opacity 0
  position absolute
  z-index 11
  left 50%
  transform translateX(-50%)
  top calc(100% + 2px)
  border 10px solid transparent
  border-bottom-color rgba(0, 0, 0, 0.9)
  transition opacity 0.2s ease
  pointer-events none

.hovertext:hover:before,
.hovertext:hover:after
  opacity 1
  visibility visible

// Mobile: hide tooltip
@media screen and (max-width: 479px)
  .hovertext:before,
  .hovertext:after
    display none
