// post structure
.post-wrap
  p
    font-size 1em
    margin 1em 0 1em 0

  .post-header
    line-height 0.4em

    h1
      margin-top 0.3em

  .post-title
    font-family $display-font-family
    font-size 2em
    line-height 1.2em
    margin-bottom 15px

  .post-title::before
    content "#"
    color $light-post-link-color
    position absolute
    left -35px
    font-weight bold
    font-family verdana
