// Capital City category - full-width dark background
$capital-city-primary = #1E2A3A
$capital-city-accent = #E8B84B
$capital-city-text = rgb(246, 240, 228)
$capital-city-text-muted = rgba(246, 240, 228, 0.6)

.category-capital-city
  background-image: url("../image/capital-city.png");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  background-origin: content-box;
  width: 60px;
  height: 60px;
  padding: 10px;
  box-sizing: content-box;
  position: absolute;
  left: -100px;
  top: 5px;
  background-color: $light-background-color;

.post-capital-city
  position: relative;
  max-width: none;
  width: 100vw;
  margin-left: 50%;
  transform: translateX(-50%);
  padding: 2.5em calc((100vw - 780px) / 2);
  background-color: $capital-city-primary;
  color: $capital-city-text;
  border: none;
  border-radius: 0;
  clip-path: polygon(0 15px, 100% 0, 100% calc(100% - 15px), 0 100%);

  .post-title
    color: $capital-city-text;

  .post-title::before
    color: $capital-city-accent;

  .post-meta,
  .post-meta a,
  .post-time,
  .post-author
    color: $capital-city-text-muted;

  .post-content
    color: $capital-city-text;

    a
      color: $capital-city-accent;
      &:hover
        color: lighten($capital-city-accent, 20%);

    h2, h3, h4, h5, h6
      color: $capital-city-text;

    h2::before, h3::before, h4::before
      color: $capital-city-accent;

    blockquote
      border-left-color: $capital-city-accent;
      background-color: rgba(0, 0, 0, 0.15);
      color: $capital-city-text;

    code
      color: $capital-city-accent;
      background-color: rgba(0, 0, 0, 0.2);

  .category-capital-city
    left: calc((100vw - 780px) / 2 - 100px)
    top: calc(2.5em + 1.7em)

  .post-header h2
    max-width 100%

  .category-badge
    display none
