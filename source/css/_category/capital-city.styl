// Capital City category - light blue background
$capital-city-bg = rgba(172, 204, 253, 0.2)

.category-capital-city
  background-image: url("../image/capital-city.png");
  background-size: 60px 60px;
  width: 60px;
  height: 60px;
  position: absolute;
  left: -80px;
  top: 5px;

.post-capital-city
  background-color: $capital-city-bg;
  border: solid 1px $light-font-secondary-color;
  border-radius: 10px;
  padding: 0 20px;
  margin: 20px 0;

  .post-header h2
    max-width 90%
