// Hexagon category - full-width dark background
$hexagon-primary = #183B3F
$hexagon-accent = #81D8D9
$hexagon-text = rgb(246, 240, 228)
$hexagon-text-muted = rgba(246, 240, 228, 0.6)

.category-hexagon
  background-image: url("../image/hexagon.png");
  background-size: 60px 60px;
  width: 60px;
  height: 60px;
  position: absolute;
  left: -80px;
  top: 5px;
  background-color: $light-background-color;
  padding: 5px;

.post-hexagon
  position: relative;
  max-width: none;
  width: 100vw;
  margin-left: 50%;
  transform: translateX(-50%);
  padding: 2.5em calc((100vw - 780px) / 2);
  background-color: $hexagon-primary;
  color: $hexagon-text;
  border: none;
  border-radius: 0;
  clip-path: polygon(0 15px, 100% 0, 100% calc(100% - 15px), 0 100%);

  .post-title
    color: $hexagon-text;

  .post-title::before
    color: $hexagon-accent;

  .post-meta,
  .post-meta a,
  .post-time,
  .post-author
    color: $hexagon-text-muted;

  .post-content
    color: $hexagon-text;

    a
      color: $hexagon-accent;
      &:hover
        color: lighten($hexagon-accent, 20%);

    h2, h3, h4, h5, h6
      color: $hexagon-text;

    h2::before, h3::before, h4::before
      color: $hexagon-accent;

    blockquote
      border-left-color: $hexagon-accent;
      background-color: rgba(0, 0, 0, 0.15);
      color: $hexagon-text;

    code
      color: $hexagon-accent;
      background-color: rgba(0, 0, 0, 0.2);

  .category-hexagon
    opacity: 0.7
    left: calc((100vw - 780px) / 2 - 80px)
    top: calc(2em + 1.7em)

  .post-header h2
    max-width 100%

  .category-badge
    display none
